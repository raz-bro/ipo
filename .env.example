# Copy this file to .env and fill in your values.
# Never commit your real .env file.

# --- Telegram (required) ----------------------------------------------
# Get BOT_TOKEN from @BotFather, CHAT_ID from @userinfobot (see README.md)
BOT_TOKEN=
CHAT_ID=

# --- Scheduler ----------------------------------------------------------
# How often (minutes) to re-check IPO listings + GMP.
POLL_INTERVAL_MINUTES=10
# Send an immediate poll cycle as soon as the bot starts (true/false).
RUN_IMMEDIATELY_ON_START=true
# 24-hour HH:MM, local to TIMEZONE below.
MORNING_SUMMARY_TIME=08:00
EVENING_SUMMARY_TIME=20:00
ENABLE_MORNING_SUMMARY=true
ENABLE_EVENING_SUMMARY=true
TIMEZONE=Asia/Kolkata

# --- GMP change-detection thresholds ------------------------------------
# Notify if GMP moves by at least this many rupees...
GMP_ABS_THRESHOLD=5
# ...OR by at least this percentage (whichever triggers first).
GMP_PCT_THRESHOLD=5

# --- Networking -----------------------------------------------------------
REQUEST_TIMEOUT=20
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=3

# --- Paths (relative to the ipo_bot/ directory) ---------------------------
DB_PATH=database/ipo_bot.db
LOG_DIR=logs
LOG_FILE=app.log
LOG_LEVEL=INFO
CSV_EXPORT_DIR=exports

# --- Data sources (override only if a site moves/renames its report) ------
# GROWW_IPO_URL=https://groww.in/ipo
# CHITTORGARH_MAINBOARD_URL=https://www.chittorgarh.com/report/mainline-ipo-list-in-india-bse-nse/83/
# CHITTORGARH_SME_URL=https://www.chittorgarh.com/report/sme-ipo-list-in-india-bse-sme-nse-emerge/84/
# INVESTORGAIN_GMP_URL=https://www.investorgain.com/report/live-ipo-gmp/331/
# IPOWATCH_GMP_URL=https://ipowatch.in/ipo-grey-market-premium-latest-ipo-gmp/
